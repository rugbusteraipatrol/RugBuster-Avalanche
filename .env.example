# Avalanche C-Chain RPC
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Avalanche Fuji testnet RPC
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Polling settings
POLL_SECONDS=12
START_BLOCK_LOOKBACK=250
OUTPUT_CSV=data/avalanche_tokens.csv

# Optional: override factories as JSON object.
# DEX_FACTORIES_JSON={"trader_joe_v1":"0x9Ad6C38BE94206cA50bb0d90783181662f0Cfa10","pangolin_v1":"0xE54Ca86531e17Ef3616d22Ca28b0D458b6C89106"}

# Deployment / publisher settings
# Use a Fuji-funded test wallet. Never commit a real private key.
PRIVATE_KEY=
REGISTRY_ADDRESS=
